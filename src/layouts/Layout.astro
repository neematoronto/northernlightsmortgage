---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Northern Lights Mortgage — Stress-free mortgage guidance for Toronto first-time home buyers.' } = Astro.props;

const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/services', label: 'Services' },
  { href: '/resources', label: 'Resources' },
  { href: '/contact', label: 'Contact' },
];

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Northern Lights Mortgage</title>
  </head>
  <body class="flex flex-col min-h-screen">

    <!-- Navigation -->
    <header class="bg-white border-b border-gray-100 shadow-sm sticky top-0 z-50">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <!-- Logo -->
          <a href="/" class="flex items-center">
            <img
              src="/logo.png"
              alt="Northern Lights Mortgage"
              class="w-[120px] h-auto"
            />
          </a>

          <!-- Desktop Nav -->
          <div class="hidden md:flex items-center gap-1">
            {navLinks.map(link => (
              <a
                href={link.href}
                class={`px-4 py-2 text-sm font-medium rounded-md transition-all duration-150 hover:text-brand hover:bg-brand/5 ${
                  isActive(link.href)
                    ? 'text-brand underline underline-offset-4 decoration-2'
                    : 'text-gray-600'
                }`}
              >
                {link.label}
              </a>
            ))}
            <a href="/contact" class="ml-3 btn-primary text-sm px-5 py-2">
              Free Consultation
            </a>
          </div>

          <!-- Mobile hamburger -->
          <button
            id="mobile-menu-btn"
            class="md:hidden p-2 rounded-md text-gray-600 hover:bg-gray-100 transition-colors"
            aria-label="Open menu"
          >
            <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
            <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>

        <!-- Mobile Menu -->
        <div id="mobile-menu" class="hidden md:hidden pb-4">
          <div class="flex flex-col gap-1 pt-2 border-t border-gray-100">
            {navLinks.map(link => (
              <a
                href={link.href}
                class={`px-4 py-3 text-sm font-medium rounded-md hover:text-brand hover:bg-brand/5 transition-colors ${
                  isActive(link.href) ? 'text-brand underline underline-offset-4 decoration-2' : 'text-gray-700'
                }`}
              >
                {link.label}
              </a>
            ))}
            <a href="/contact" class="mt-2 btn-primary text-sm text-center">
              Free Consultation
            </a>
          </div>
        </div>
      </nav>
    </header>

    <!-- Page Content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Blue CTA Banner -->
    <section class="bg-brand py-16">
      <div class="max-w-4xl mx-auto px-4 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          Ready to Find Your Perfect Mortgage?
        </h2>
        <p class="text-white/80 text-lg mb-8 max-w-xl mx-auto">
          Book a free, no-obligation consultation and get expert guidance tailored to your situation.
        </p>
        <a href="/contact" class="btn-outline text-base px-8 py-4">
          Get Your Free Consultation
        </a>
      </div>
    </section>

    <!-- Footer -->
    <footer class="bg-gray-900 text-gray-300">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">
          <!-- Column 1: Brand -->
          <div>
            <div class="mb-4">
              <img
                src="/logo.png"
                alt="Northern Lights Mortgage"
                class="h-10 w-auto brightness-0 invert"
              />
            </div>
            <p class="text-sm leading-relaxed text-gray-400">
              Helping Toronto's first-time buyers navigate the mortgage process with confidence and clarity.
            </p>
          </div>

          <!-- Column 2: Quick Links -->
          <div>
            <h3 class="text-white font-semibold mb-4">Quick Links</h3>
            <ul class="space-y-2 text-sm">
              {navLinks.map(link => (
                <li>
                  <a href={link.href} class="hover:text-white transition-colors duration-150">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Column 3: Services -->
          <div>
            <h3 class="text-white font-semibold mb-4">Services</h3>
            <ul class="space-y-2 text-sm">
              <li><a href="/services" class="hover:text-white transition-colors">First-Time Buyer Mortgages</a></li>
              <li><a href="/services" class="hover:text-white transition-colors">Pre-Approvals</a></li>
              <li><a href="/services" class="hover:text-white transition-colors">Mortgage Renewals</a></li>
              <li><a href="/services" class="hover:text-white transition-colors">Refinancing</a></li>
            </ul>
          </div>

          <!-- Column 4: Contact -->
          <div>
            <h3 class="text-white font-semibold mb-4">Contact Us</h3>
            <ul class="space-y-3 text-sm">
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 mt-0.5 text-brand flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
                </svg>
                <a href="tel:+14165550100" class="hover:text-white transition-colors">(416) 555-0100</a>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 mt-0.5 text-brand flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
                </svg>
                <a href="mailto:info@northernlightsmortgage.ca" class="hover:text-white transition-colors">info@northernlightsmortgage.ca</a>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 mt-0.5 text-brand flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                </svg>
                <span>123 Bay Street, Suite 400<br/>Toronto, ON M5H 2R4</span>
              </li>
            </ul>
          </div>
        </div>

        <div class="border-t border-gray-700 mt-10 pt-6 flex flex-col sm:flex-row justify-between items-center gap-4 text-xs text-gray-500">
          <p>&copy; {new Date().getFullYear()} Northern Lights Mortgage. All rights reserved.</p>
          <p>Licensed Mortgage Brokerage — FSRA Licence #XXXXX | Ontario, Canada</p>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      const iconOpen = document.getElementById('icon-open');
      const iconClose = document.getElementById('icon-close');

      btn?.addEventListener('click', () => {
        const isOpen = !menu?.classList.contains('hidden');
        menu?.classList.toggle('hidden', isOpen);
        iconOpen?.classList.toggle('hidden', !isOpen);
        iconClose?.classList.toggle('hidden', isOpen);
      });
    </script>
  </body>
</html>
