---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Book a free mortgage consultation with Northern Lights Mortgage in Toronto.">

  <!-- Page Hero -->
  <section class="bg-[#F5F5F5] py-16 md:py-20 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <p class="text-brand text-sm font-semibold uppercase tracking-widest mb-3">Contact Us</p>
        <h1 class="text-4xl md:text-5xl font-extrabold mb-4 text-charcoal">Let's Talk Mortgages</h1>
        <p class="text-body text-lg leading-relaxed">
          Book your free, no-obligation consultation. We're available evenings and weekends because buying a home doesn't wait until Monday.
        </p>
      </div>
    </div>
  </section>

  <!-- Two-column Contact Layout -->
  <section class="py-20 bg-[#F5F5F5]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-10">

        <!-- Left: Contact Info -->
        <div class="lg:col-span-2 space-y-8">
          <div>
            <h2 class="text-2xl font-bold text-charcoal mb-6">Get in Touch</h2>
            <div class="space-y-5">
              <!-- Phone -->
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-brand/10 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-brand" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-charcoal mb-0.5">Phone</p>
                  <a href="tel:+14165550100" class="text-brand hover:text-brand-dark transition-colors font-medium">(416) 555-0100</a>
                  <p class="text-gray-500 text-sm mt-1">Mon–Fri 8am–8pm · Sat–Sun 9am–5pm</p>
                </div>
              </div>

              <!-- Email -->
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-brand/10 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-brand" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-charcoal mb-0.5">Email</p>
                  <a href="mailto:info@northernlightsmortgage.ca" class="text-brand hover:text-brand-dark transition-colors font-medium break-all">
                    info@northernlightsmortgage.ca
                  </a>
                  <p class="text-gray-500 text-sm mt-1">We reply within 2 business hours</p>
                </div>
              </div>

              <!-- Address -->
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-brand/10 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-brand" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-charcoal mb-0.5">Office</p>
                  <address class="not-italic text-gray-700">
                    123 Bay Street, Suite 400<br/>
                    Toronto, ON M5H 2R4
                  </address>
                  <p class="text-gray-500 text-sm mt-1">Meetings by appointment</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Why consult with us -->
          <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">
            <h3 class="font-bold text-charcoal mb-4">What to Expect</h3>
            <ul class="space-y-3">
              {[
                'A 30-minute call at no cost or obligation',
                'Honest advice tailored to your situation',
                'A clear idea of your borrowing power',
                'Answers to all your mortgage questions',
              ].map(item => (
                <li class="flex items-start gap-2 text-sm text-gray-700">
                  <svg class="w-4 h-4 text-brand mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Right: Contact Form -->
        <div class="lg:col-span-3">
          <div class="bg-white border border-gray-200 rounded-2xl p-8 md:p-10 shadow-sm">
            <h2 class="text-2xl font-bold text-charcoal mb-2">Book a Free Consultation</h2>
            <p class="text-gray-500 text-sm mb-8">Fill in your details and we'll reach out within one business hour.</p>

            <form id="contact-form" class="space-y-5" novalidate>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="first-name" class="block text-sm font-medium text-gray-700 mb-1.5">First Name <span class="text-red-500">*</span></label>
                  <input
                    type="text"
                    id="first-name"
                    name="first-name"
                    required
                    placeholder="Jane"
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand/30 focus:border-brand transition-colors"
                  />
                </div>
                <div>
                  <label for="last-name" class="block text-sm font-medium text-gray-700 mb-1.5">Last Name <span class="text-red-500">*</span></label>
                  <input
                    type="text"
                    id="last-name"
                    name="last-name"
                    required
                    placeholder="Smith"
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand/30 focus:border-brand transition-colors"
                  />
                </div>
              </div>

              <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">Email Address <span class="text-red-500">*</span></label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="jane@example.com"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand/30 focus:border-brand transition-colors"
                />
              </div>

              <div>
                <label for="phone" class="block text-sm font-medium text-gray-700 mb-1.5">Phone Number</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  placeholder="(416) 555-0000"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand/30 focus:border-brand transition-colors"
                />
              </div>

              <div>
                <label for="inquiry-type" class="block text-sm font-medium text-gray-700 mb-1.5">What can we help with?</label>
                <select
                  id="inquiry-type"
                  name="inquiry-type"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand/30 focus:border-brand transition-colors bg-white text-gray-700"
                >
                  <option value="">Select an option…</option>
                  <option value="first-time">First-Time Buyer Mortgage</option>
                  <option value="pre-approval">Pre-Approval</option>
                  <option value="renewal">Mortgage Renewal</option>
                  <option value="refinancing">Refinancing</option>
                  <option value="other">Other / General Inquiry</option>
                </select>
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-gray-700 mb-1.5">Message <span class="text-red-500">*</span></label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows={5}
                  placeholder="Tell us a little about your situation — where you're at in the process, what you're looking for, and any questions you have."
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand/30 focus:border-brand transition-colors resize-none"
                ></textarea>
              </div>

              <div>
                <button
                  type="submit"
                  class="w-full btn-primary text-base py-4 text-center"
                >
                  Send My Request →
                </button>
                <p class="text-xs text-gray-400 text-center mt-3">
                  Your information is kept confidential and never shared with third parties.
                </p>
              </div>
            </form>

            <!-- Success message (hidden) -->
            <div id="form-success" class="hidden text-center py-10">
              <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-charcoal mb-2">Message Sent!</h3>
              <p class="text-gray-600">Thanks for reaching out. We'll be in touch within one business hour.</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }
    // Simulate submission — wire up to a backend or service like Resend/Netlify Forms in production
    form.classList.add('hidden');
    success?.classList.remove('hidden');
  });
</script>
