---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home" description="Northern Lights Mortgage — Your first home starts here. Expert mortgage guidance for Toronto first-time buyers.">

  <!-- Hero Section -->
  <section class="bg-white py-20 md:py-28 border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 lg:pr-16">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

        <!-- Left: Text content -->
        <div>
          <span class="inline-block bg-brand/10 text-brand text-sm font-semibold px-4 py-1.5 rounded-full mb-6">
            Toronto's First-Time Buyer Specialists
          </span>
          <h1 class="text-4xl md:text-6xl font-extrabold leading-tight mb-6 text-charcoal">
            Your First Home<br/>Starts Here
          </h1>
          <p class="text-xl text-body leading-relaxed mb-10 max-w-lg">
            Stress-free mortgage guidance for Toronto first-time buyers. We simplify the process, find you the best rates, and stand by you every step of the way.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/contact" class="btn-primary text-base px-8 py-4 text-center">
              Get Your Free Consultation
            </a>
            <a href="/services" class="inline-block text-brand font-semibold px-8 py-4 rounded-lg hover:bg-brand/5 transition-all duration-200 text-center">
              Explore Services →
            </a>
          </div>
        </div>

        <!-- Right: Photo placeholder -->
        <div class="flex justify-center lg:justify-end">
          <div
            class="w-full max-w-[480px] rounded-2xl border border-gray-200 flex flex-col items-center justify-center gap-4"
            style="background-color: #F0F0F0; height: 520px;"
          >
            <svg class="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <p class="text-gray-400 text-sm font-medium">Your Photo Here</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Trust Blocks -->
  <section class="bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Trust Block 1 -->
        <div class="flex items-start gap-5">
          <div class="w-14 h-14 bg-brand/10 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-7 h-7 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-bold text-charcoal mb-1">Best Rates</h3>
            <p class="text-gray-600">We compare dozens of lenders to secure the lowest rate available for your unique situation.</p>
          </div>
        </div>
        <!-- Trust Block 2 -->
        <div class="flex items-start gap-5">
          <div class="w-14 h-14 bg-brand/10 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-7 h-7 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-bold text-charcoal mb-1">Expert Guidance</h3>
            <p class="text-gray-600">A licensed mortgage broker who knows Toronto's market inside-out guides you from start to close.</p>
          </div>
        </div>
        <!-- Trust Block 3 -->
        <div class="flex items-start gap-5">
          <div class="w-14 h-14 bg-brand/10 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-7 h-7 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-bold text-charcoal mb-1">Fast Approvals</h3>
            <p class="text-gray-600">Our streamlined process means pre-approvals in as little as 24 hours, so you can act quickly.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-20 bg-[#F5F5F5]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="section-heading">How It Works</h2>
        <p class="section-subheading">From first call to keys in hand — here's our simple four-step journey.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 relative">
        {[
          {
            step: '01',
            title: 'Free Consultation',
            desc: 'Book a no-obligation call. We learn about your goals, income, and timeline.',
            icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
          },
          {
            step: '02',
            title: 'Pre-Approval',
            desc: 'We gather your documents and submit to lenders to secure your pre-approval fast.',
            icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
          },
          {
            step: '03',
            title: 'Rate Shopping',
            desc: 'We compare rates from banks, credit unions, and private lenders to find your best deal.',
            icon: 'M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3',
          },
          {
            step: '04',
            title: 'Close & Move In',
            desc: 'We handle the paperwork and coordinate with your lawyer so you can focus on moving.',
            icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6',
          },
        ].map((item, i) => (
          <div class="card text-center relative">
            <div class="w-12 h-12 bg-brand rounded-xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon}/>
              </svg>
            </div>
            <div class="text-5xl font-black text-brand/10 absolute top-4 right-4 leading-none select-none">{item.step}</div>
            <h3 class="text-lg font-bold text-charcoal mb-2">{item.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="section-heading">What Our Clients Say</h2>
        <p class="section-subheading">Real stories from Toronto first-time buyers we've helped.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {
            quote: "I had no idea where to start with buying my first condo. Northern Lights walked me through everything and got me a rate I didn't think was possible. I closed in 30 days!",
            name: 'Sarah M.',
            location: 'Leslieville, Toronto',
            stars: 5,
          },
          {
            quote: "The pre-approval was fast and painless. They explained everything in plain language and were always available to answer my questions. Highly recommend for any first-time buyer.",
            name: 'James K.',
            location: 'North York, Toronto',
            stars: 5,
          },
          {
            quote: "As a newcomer to Canada, I was nervous about the mortgage process. The team was patient, thorough, and found me a fantastic rate. We're in our first home now — couldn't be happier!",
            name: 'Priya & Rajan S.',
            location: 'Scarborough, Toronto',
            stars: 5,
          },
        ].map(t => (
          <div class="card flex flex-col">
            <div class="flex gap-1 mb-4">
              {Array.from({ length: t.stars }).map(() => (
                <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
            <p class="text-gray-600 italic flex-1 mb-5 leading-relaxed">"{t.quote}"</p>
            <div class="flex items-center gap-3 pt-4 border-t border-gray-100">
              <div class="w-10 h-10 bg-brand/10 rounded-full flex items-center justify-center text-brand font-bold text-sm">
                {t.name.charAt(0)}
              </div>
              <div>
                <p class="font-semibold text-charcoal text-sm">{t.name}</p>
                <p class="text-xs text-gray-500">{t.location}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>
